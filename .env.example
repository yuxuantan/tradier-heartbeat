# Tradier
TRADIER_ACCESS_TOKEN=your_tradier_access_token
TRADIER_ACCOUNT_ID=your_tradier_account_id

# Email backup alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=alerts@example.com
EMAIL_TO=you@example.com

# Pushover acknowledgement-required emergency alerts
PUSHOVER_APP_TOKEN=your_30_character_application_token
PUSHOVER_USER_KEY=your_pushover_user_or_group_key
PUSHOVER_RETRY_SECS=60
PUSHOVER_EXPIRE_SECS=3600

# Optional: restrict delivery to one named device or override the app sound.
# PUSHOVER_DEVICE=iphone
# PUSHOVER_SOUND=your_pushover_sound_name
